# android/fastlane/Fastfile — Nazar
# frozen_string_literal: true

default_platform :android

PACKAGE_NAME = "com.nazar.fal"
PROJECT_ROOT = File.expand_path("../../", __dir__)
FLUTTER_BIN  = "flutter"

def dart_define_args
  {
    "APP_ENV"              => ENV["DART_DEFINE_APP_ENV"] || "prod",
    "SUPABASE_URL"         => ENV["DART_DEFINE_SUPABASE_URL"],
    "SUPABASE_ANON_KEY"    => ENV["DART_DEFINE_SUPABASE_ANON_KEY"],
    "RC_ANDROID_KEY"       => ENV["DART_DEFINE_RC_ANDROID_KEY"],
    "ADMOB_APP_ID_ANDROID" => ENV["DART_DEFINE_ADMOB_APP_ANDROID"],
  }.map { |k, v| "--dart-define=#{k}=#{v}" }.join(" ")
end

platform :android do
  desc "Build AAB and upload to Play Store internal track"
  lane :beta do
    version   = ENV["APP_VERSION"] || "1.0.0"
    build_num = ENV["BUILD_NUMBER"] || Time.now.utc.strftime("%Y%m%d%H%M")

    Dir.chdir(PROJECT_ROOT) do
      sh "#{FLUTTER_BIN} pub get"
      sh "#{FLUTTER_BIN} build appbundle --release " \
         "--build-name=#{version} --build-number=#{build_num} #{dart_define_args}"
    end

    upload_to_play_store(
      package_name:            PACKAGE_NAME,
      track:                   "internal",
      aab:                     "#{PROJECT_ROOT}/build/app/outputs/bundle/release/app-release.aab",
      json_key:                "fastlane/keys/play_store_key.json",
      skip_upload_apk:         true,
      skip_upload_metadata:    true,
      skip_upload_changelogs:  true,
      skip_upload_images:      true,
      skip_upload_screenshots: true,
      release_status:          "draft",
    )
  end

  desc "Build AAB and submit to Play Store production (10% rollout)"
  lane :release do
    version   = ENV["APP_VERSION"]
    build_num = ENV["BUILD_NUMBER"]

    Dir.chdir(PROJECT_ROOT) do
      sh "#{FLUTTER_BIN} pub get"
      sh "#{FLUTTER_BIN} build appbundle --release " \
         "--build-name=#{version} --build-number=#{build_num} #{dart_define_args}"
    end

    upload_to_play_store(
      package_name:            PACKAGE_NAME,
      track:                   "production",
      rollout:                 "0.1",
      aab:                     "#{PROJECT_ROOT}/build/app/outputs/bundle/release/app-release.aab",
      json_key:                "fastlane/keys/play_store_key.json",
      skip_upload_apk:         true,
      release_status:          "inProgress",
    )
  end
end
