# ios/fastlane/Fastfile — Nazar
# frozen_string_literal: true

default_platform :ios

BUNDLE_ID    = "com.nazar.fal"
APP_NAME     = "Nazar"
PROJECT_ROOT = File.expand_path("../../", __dir__)
FLUTTER_BIN  = "flutter"

def dart_defines_for(env)
  base = {
    "SUPABASE_URL"      => ENV["DART_DEFINE_SUPABASE_URL"],
    "SUPABASE_ANON_KEY" => ENV["DART_DEFINE_SUPABASE_ANON_KEY"],
    "RC_IOS_KEY"        => ENV["DART_DEFINE_RC_IOS_KEY"],
    "ADMOB_APP_ID_IOS"  => ENV["DART_DEFINE_ADMOB_APP_IOS"],
  }
  env_value = env == :prod ? "prod" : "staging"
  base.merge("APP_ENV" => env_value)
      .map { |k, v| "--dart-define=#{k}=#{v}" }
      .join(" ")
end

def build_flutter_ios(env:)
  version   = ENV["APP_VERSION"]
  build_num = ENV["BUILD_NUMBER"]
  defines   = dart_defines_for(env)

  Dir.chdir(PROJECT_ROOT) do
    sh "#{FLUTTER_BIN} pub get"
    cmd = "#{FLUTTER_BIN} build ipa --release --no-codesign #{defines}"
    cmd += " --build-name=#{version} --build-number=#{build_num}" if version && build_num
    sh cmd
  end
end

platform :ios do
  desc "Build staging IPA and upload to TestFlight"
  lane :beta do
    setup_ci if ENV["CI"]
    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: "fastlane/keys/asc_api_key.json",
      duration:     1200,
      in_house:     false,
    )
    match(type: "appstore", readonly: true, api_key: api_key, app_identifier: BUNDLE_ID)
    build_flutter_ios(env: :staging)
    gym(
      workspace: "Runner.xcworkspace", scheme: "Runner",
      export_method: "app-store",
      output_directory: "build/ios/ipa",
      output_name: "#{APP_NAME}-staging.ipa",
      xcargs: "CODE_SIGN_STYLE=Manual",
      export_options: { provisioningProfiles: { BUNDLE_ID => "match AppStore #{BUNDLE_ID}" } },
    )
    upload_to_testflight(
      api_key: api_key,
      ipa: "build/ios/ipa/#{APP_NAME}-staging.ipa",
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build production IPA and submit to App Store"
  lane :release do
    setup_ci if ENV["CI"]
    api_key = app_store_connect_api_key(
      key_id:       ENV["ASC_KEY_ID"],
      issuer_id:    ENV["ASC_ISSUER_ID"],
      key_filepath: "fastlane/keys/asc_api_key.json",
      duration:     1200,
      in_house:     false,
    )
    match(type: "appstore", readonly: true, api_key: api_key, app_identifier: BUNDLE_ID)
    build_flutter_ios(env: :prod)
    gym(
      workspace: "Runner.xcworkspace", scheme: "Runner",
      export_method: "app-store",
      output_directory: "build/ios/ipa",
      output_name: "#{APP_NAME}-release.ipa",
      xcargs: "CODE_SIGN_STYLE=Manual",
      export_options: { provisioningProfiles: { BUNDLE_ID => "match AppStore #{BUNDLE_ID}" } },
    )
    upload_to_app_store(
      api_key: api_key,
      ipa: "build/ios/ipa/#{APP_NAME}-release.ipa",
      submit_for_review: false,
      automatic_release: false,
      force: true,
      skip_metadata: true,
      skip_screenshots: true,
    )
  end
end
